{
  "name": "idea-manager",
  "version": "2.4.1",
  "description": "AI-powered idea & task manager for developers. Brainstorm → structured tasks → AI agent execution. CodeMirror editor with slash commands, MCP Server, Claude/Gemini/Codex support. Local-first SQLite, cross-PC Git sync.",
  "keywords": [
    "idea-manager",
    "task-manager",
    "project-management",
    "ai",
    "mcp",
    "mcp-server",
    "claude",
    "claude-code",
    "gemini",
    "codex",
    "brainstorm",
    "prompt",
    "prompt-engineering",
    "developer-tools",
    "productivity",
    "todo",
    "notes",
    "markdown-editor",
    "codemirror",
    "local-first",
    "sqlite",
    "ai-agent",
    "autonomous-agent",
    "structuring"
  ],
  "author": "navskh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/navskh/IM.git"
  },
  "bin": {
    "im": "./bin/im.js"
  },
  "files": [
    "README.md",
    "bin/",
    "src/",
    "public/",
    ".next/BUILD_ID",
    ".next/server/",
    ".next/static/",
    ".next/required-server-files.json",
    ".next/required-server-files.js",
    ".next/routes-manifest.json",
    ".next/build-manifest.json",
    ".next/react-loadable-manifest.json",
    ".next/prerender-manifest.json",
    ".next/prerender-manifest.js",
    ".next/images-manifest.json",
    ".next/package.json",
    "!.next/**/*.nft.json",
    "next.config.mjs",
    "next-env.d.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 3456",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "mcp": "tsx src/cli.ts mcp",
    "postinstall": "node bin/postinstall.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@uiw/react-codemirror": "^4.25.9",
    "commander": "^14.0.3",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "open": "^11.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.1.6"
