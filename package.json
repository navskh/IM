{
  "name": "idea-manager",
  "version": "1.4.1",
  "description": "Turn free-form brainstorming into structured task trees with AI-generated prompts. Built-in MCP Server for autonomous AI agent execution. Local-first with SQLite, cross-PC sync via Git.",
  "keywords": [
    "brainstorm",
    "ai",
    "mcp",
    "idea",
    "task-manager",
    "prompt",
    "structuring",
    "project-management",
    "sqlite",
    "local-first"
  ],
  "author": "navskh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/navskh/IM.git"
  },
  "bin": {
    "im": "./bin/im.js"
  },
  "files": [
    "README.md",
    "bin/",
    "src/",
    "public/",
    ".next/",
    "!.next/cache/",
    "!.next/types/",
    "!.next/trace",
    "!.next/trace-build",
    "!.next/diagnostics/",
    "!.next/**/*.nft.json",
    "next.config.mjs",
    "tsconfig.json",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 3456",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "mcp": "tsx src/cli.ts mcp",
    "postinstall": "node bin/postinstall.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "open": "^11.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tsx": "^4.21.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.1.6"
  }
}
